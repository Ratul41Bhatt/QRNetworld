	},
	"item": [
		{
			"name": "Gateway Diagnostics",
			"item": [
				{
					"name": "Get Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/status",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"status"
							]
						},
						"description": "Returns connection status of the Firebase database and MQTT broker."
					},
					"response": []
				}
			]
		},
		{
			"name": "Payment Webhook Simulation",
			"item": [
				{
					"name": "Trigger Payment Callback (Success Scenario)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": \"250.00\",\n    \"invoice\": \"123456\",\n    \"rrn\": \"777888999000\",\n    \"tid\": \"20501603\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/payment",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"payment"
							]
						},
						"description": "Simulates a payment webhook trigger. The gateway automatically translates the TID, resolves the device SN, and publishes the notification payload to multiple MQTT topics."
					},
					"response": []
				},
				{
					"name": "Trigger Payment Callback (Unmapped TID Scenario)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": \"150.00\",\n    \"invoice\": \"654321\",\n    \"rrn\": \"999888777666\",\n    \"tid\": \"99999999\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/payment",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"payment"
							]
						},
						"description": "Simulates a webhook trigger with an unmapped TID to verify that the gateway records the transaction history as failed."
					},
					"response": []
				}
			]
		},
